// Eco Retreat — data model (Phase 0 schema; migrations in Phase 2+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum AdminRole {
  ADMIN
  STAFF
}

model Program {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String        @db.Text
  pricePaise   Int
  durationDays Int?
  isActive     Boolean       @default(true)
  dates        ProgramDate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ProgramDate {
  id        String        @id @default(cuid())
  programId String
  program   Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  startDate DateTime      @db.Date
  endDate   DateTime?     @db.Date
  capacity  Int
  holds     BookingHold[]
  bookings  Booking[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([programId, startDate])
  @@index([startDate])
}

model BookingHold {
  id              String      @id @default(cuid())
  programDateId   String
  programDate     ProgramDate @relation(fields: [programDateId], references: [id], onDelete: Cascade)
  guestEmail      String
  guestName       String?
  seats           Int         @default(1)
  expiresAt       DateTime
  razorpayOrderId String?     @unique
  booking         Booking?
  createdAt       DateTime    @default(now())

  @@index([programDateId, expiresAt])
}

model Booking {
  id            String        @id @default(cuid())
  programDateId String
  programDate   ProgramDate   @relation(fields: [programDateId], references: [id])
  holdId        String        @unique
  hold          BookingHold   @relation(fields: [holdId], references: [id])
  status        BookingStatus @default(PENDING)
  paymentId     String?       @unique
  seats         Int
  guestEmail    String
  guestName     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model WebhookEvent {
  id        String   @id
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model PrivacyPolicyVersion {
  id          String   @id @default(cuid())
  version     String
  content     String   @db.Text
  publishedAt DateTime @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
}
